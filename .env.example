# Copy to .env.local for development. Set the same keys in the Vercel project (Settings → Environment Variables).
# Vite exposes only variables prefixed with VITE_ to the browser — never put service-role secrets there.

# SkyWindow's own Supabase project (ujbvcjqsovgrtauwjbzq) — do not use Meetmap's database.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Production web origin (no trailing slash). Required for native Android/iOS builds —
# Capacitor serves the UI locally; /api routes must call your deployed Vercel app.
VITE_APP_ORIGIN=https://skywindow.vercel.app

# Claude API key for horizon photo analysis (server-side /api only — not bundled into the client).
# Prefer this name; server also accepts legacy VITE_ANTHROPIC_API_KEY from older setups.
ANTHROPIC_API_KEY=

# Optional: service-role secret for JWT verify on /api/analyze-horizon.
# If omitted, the server falls back to VITE_SUPABASE_ANON_KEY (same as the browser client).
SUPABASE_SERVICE_ROLE_KEY=
